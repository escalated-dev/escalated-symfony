<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <style>
        body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; margin: 0; padding: 0; background-color: #f5f5f5; }
        .container { max-width: 600px; margin: 0 auto; background-color: #ffffff; }
        .header { padding: 24px; background-color: {{ branding.primary_color|default('#4F46E5') }}; color: #ffffff; }
        .header h1 { margin: 0; font-size: 18px; }
        .content { padding: 24px; }
        .footer { padding: 16px 24px; background-color: #f9fafb; color: #6b7280; font-size: 12px; text-align: center; }
    </style>
</head>
<body>
    <div class="container">
        <div class="header">
            {% if branding.logo_url is defined and branding.logo_url %}
                <img src="{{ branding.logo_url }}" alt="{{ branding.company_name|default('Support') }}" style="max-height: 40px;">
            {% else %}
                <h1>{{ branding.company_name|default('Support') }}</h1>
            {% endif %}
        </div>
        <div class="content">
            {% block content %}{% endblock %}
        </div>
        <div class="footer">
            {{ branding.footer_text|default('Powered by Escalated') }}
        </div>
    </div>
</body>
</html>
